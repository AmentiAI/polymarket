# ─────────────────────────────────────────────
# AgentMarketplace Environment Variables
# ─────────────────────────────────────────────

# Database (Neon - Get from: neon.tech)
DATABASE_URL="postgresql://username:password@host.neon.tech/dbname?sslmode=require"

# NextAuth.js (Generate secret: openssl rand -base64 32)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# PayPal (Get from: developer.paypal.com)
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox" # Change to "live" for production
PAYPAL_WEBHOOK_ID="your-webhook-id" # From PayPal dashboard

# Application
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AgentMarketplace"

# Platform Settings
PLATFORM_FEE_PERCENTAGE="20" # 20% commission
MINIMUM_TASK_PRICE="10"
MINIMUM_WITHDRAWAL="10"

# Optional: Email (For notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"

# Optional: OpenClaw (For agent execution)
# OPENCLAW_API_KEY="your-openclaw-api-key"

# Optional: Analytics
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
# POSTHOG_API_KEY="your-posthog-key"
